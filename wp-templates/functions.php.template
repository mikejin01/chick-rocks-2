/* 1. ASSET ENQUEUE + window.<GLOBAL_NAME> BRIDGE */

function <THEME_SLUG_FN>_enqueue_assets() {
    $theme_uri = set_url_scheme(get_template_directory_uri(), 'https');
    $v = (defined('WP_DEBUG') && WP_DEBUG) ? time() : '1.0';

    $css = '<CSS_ASSET>';
    $js  = '<JS_ASSET>';
    if ($css) wp_enqueue_style('<THEME_SLUG>-style', $theme_uri . '/' . $css, array(), $v);
    if ($js)  wp_enqueue_script('<THEME_SLUG>-script', $theme_uri . '/' . $js, array(), $v, true);

    if (current_user_can('edit_posts')) {
        wp_enqueue_media();
    }

    $post_id = <THEME_SLUG_FN>_get_detected_post_id();

    $page_data = array();
    if ($post_id) {
        $meta = get_post_meta($post_id);
        foreach ($meta as $key => $values) {
            if (strpos($key, '_') !== 0 || $key === '_wp_page_template') {
                $page_data[$key] = $values[0];
            }
        }
    }

    $default_media = get_option('<THEME_SLUG_FN>_default_media', array());
    if (!is_array($default_media)) $default_media = array();

    if ($js) {
        wp_localize_script('<THEME_SLUG>-script', '<GLOBAL_NAME>', array(
            'postId'          => (int) $post_id,
            'pageData'        => $page_data,
            'isLoggedIn'      => current_user_can('edit_posts'),
            'restUrl'         => set_url_scheme(esc_url_raw(rest_url()), 'https'),
            'restNonce'       => wp_create_nonce('wp_rest'),
            'themeUrl'        => $theme_uri,
            'currentLanguage' => 'en',
            'defaultMedia'    => $default_media,
        ));
    }
}
add_action('wp_enqueue_scripts', '<THEME_SLUG_FN>_enqueue_assets');

