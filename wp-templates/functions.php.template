/* 2. POST-ID DETECTION */

function <THEME_SLUG_FN>_get_detected_post_id() {
    $post_id = get_queried_object_id();

    $req_uri  = isset($_SERVER['REQUEST_URI']) ? $_SERVER['REQUEST_URI'] : '';
    $req_path = $req_uri ? parse_url($req_uri, PHP_URL_PATH) : '';
    if (!is_string($req_path)) $req_path = '';

    if (!$post_id && ($req_path === '' || $req_path === '/' || is_front_page())) {
        $post_id = (int) get_option('page_on_front');
    }
    if (!$post_id) {
        $pagename = get_query_var('pagename');
        if ($pagename) {
            $page = get_page_by_path(ltrim($pagename, '/'));
            if ($page) $post_id = $page->ID;
        }
    }
    if (!$post_id) {
        $post_id = url_to_postid($req_uri);
    }
    return $post_id;
}

